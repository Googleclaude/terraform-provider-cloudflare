{
  "name": "mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "eval": "vitest run --config vitest.eval.config.ts",
    "d1:migrate:local": "wrangler d1 migrations apply audit-log --local",
