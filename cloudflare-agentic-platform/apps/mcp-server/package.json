  "dependencies": {
    "agents": "^0.3.10",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@cloudflare/workers-oauth-provider": "^0.0.5",
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.0.0"
  }
}
